 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Exercise 3: Build RAG from Scratch\n",
    "\n",
    "Build a Retrieval-Augmented Generation (RAG) system without using LangChain.\n",
    "This helps you deeply understand what frameworks do under the hood."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# pip install openai faiss-cpu sentence-transformers\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import faiss\n",
    "from sentence_transformers import SentenceTransformer\n",
    "from openai import OpenAI\n",
    "\n",
    "client = OpenAI(api_key=os.environ.get('OPENAI_API_KEY'))\n",
    "embedder = SentenceTransformer('all-MiniLM-L6-v2')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 1: Our knowledge base (documents)\n",
    "documents = [\n",
    "    \"Python is a high-level, general-purpose programming language. It was created by Guido van Rossum and first released in 1991.\",\n",
    "    \"Machine learning is a subset of artificial intelligence that enables computers to learn from data without being explicitly programmed.\",\n",
    "    \"PyTorch is an open-source machine learning framework developed by Meta AI. It is widely used for deep learning research and production.\",\n",
    "    \"Transformers are a type of neural network architecture that uses self-attention mechanisms, introduced in the paper 'Attention is All You Need' in 2017.\",\n",
    "    \"RAG (Retrieval-Augmented Generation) combines a retrieval system with a language model to generate answers grounded in retrieved documents.\",\n",
    "    \"LangChain is a framework for developing applications powered by language models. It provides tools for chaining, agents, and memory.\",\n",
    "    \"Vector databases store data as high-dimensional vectors and support semantic similarity search. Popular options include Pinecone, Weaviate, and Chroma.\",\n",
    "    \"Fine-tuning is the process of taking a pretrained model and further training it on a specific dataset to adapt it for a particular task.\"\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 2: Embed documents and build FAISS index\n",
    "print('Embedding documents...')\n",
    "doc_embeddings = embedder.encode(documents, convert_to_numpy=True)\n",
    "print(f'Embedding shape: {doc_embeddings.shape}')\n",
    "\n",
    "# Create FAISS index\n",
    "dimension = doc_embeddings.shape[1]\n",
    "index = faiss.IndexFlatL2(dimension)  # L2 (Euclidean) distance\n",
    "index.add(doc_embeddings.astype('float32'))\n",
    "print(f'FAISS index contains {index.ntotal} vectors')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 3: RAG retrieval function\n",
    "def retrieve(query: str, k: int = 3) -> list[str]:\n",
    "    query_embedding = embedder.encode([query], convert_to_numpy=True).astype('float32')\n",
    "    distances, indices = index.search(query_embedding, k)\n",
    "    return [documents[i] for i in indices[0]]\n",
    "\n",
    "# Step 4: RAG generation function\n",
    "def rag_answer(query: str, k: int = 3) -> str:\n",
    "    context_chunks = retrieve(query, k)\n",
    "    context = '\\n\\n'.join([f'[{i+1}] {chunk}' for i, chunk in enumerate(context_chunks)])\n",
    "\n",
    "    messages = [\n",
    "        {\"role\": \"system\", \"content\": \"You are a helpful assistant. Answer questions based ONLY on the provided context. If the answer is not in the context, say 'I don't have information about that.'\"},\n",
    "        {\"role\": \"user\", \"content\": f\"Context:\\n{context}\\n\\nQuestion: {query}\"}\n",
    "    ]\n",
    "\n",
    "    response = client.chat.completions.create(\n",
    "        model='gpt-3.5-turbo',\n",
    "        messages=messages,\n",
    "        temperature=0\n",
    "    )\n",
    "    return response.choices[0].message.content\n",
    "\n",
    "# Test it\n",
    "questions = [\n",
    "    \"Who created Python?\",\n",
    "    \"What is RAG?\",\n",
    "    \"What is the attention mechanism?\"\n",
    "]\n",
    "\n",
    "for q in questions:\n",
    "    print(f'\\nQ: {q}')\n",
    "    print(f'A: {rag_answer(q)}')"
   ]
  }
 ],
