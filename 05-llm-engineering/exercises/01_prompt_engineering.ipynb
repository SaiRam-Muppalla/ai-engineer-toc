 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Exercise 1: Prompt Engineering Techniques\n",
    "\n",
    "Master the most important prompting techniques used in production AI systems."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install: pip install openai\n",
    "# Set your API key: export OPENAI_API_KEY='your-key'\n",
    "# Or use a free alternative like Groq: pip install groq\n",
    "\n",
    "import os\n",
    "from openai import OpenAI\n",
    "\n",
    "client = OpenAI(api_key=os.environ.get('OPENAI_API_KEY'))\n",
    "\n",
    "def chat(messages, model='gpt-3.5-turbo', temperature=0.0):\n",
    "    response = client.chat.completions.create(\n",
    "        model=model,\n",
    "        messages=messages,\n",
    "        temperature=temperature\n",
    "    )\n",
    "    return response.choices[0].message.content"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 1. Zero-Shot Prompting ---\n",
    "response = chat([\n",
    "    {\"role\": \"user\", \"content\": \"Classify the sentiment of this text as positive, negative, or neutral:\\n\\n'The product arrived on time but the quality was disappointing.'\"}\n",
    "])\n",
    "print('Zero-shot sentiment:', response)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 2. Few-Shot Prompting ---\n",
    "few_shot_prompt = \"\"\"\n",
    "Classify the sentiment. Examples:\n",
    "\n",
    "Text: \"I love this product!\"\n",
    "Sentiment: Positive\n",
    "\n",
    "Text: \"This is the worst purchase I've made.\"\n",
    "Sentiment: Negative\n",
    "\n",
    "Text: \"It works okay, nothing special.\"\n",
    "Sentiment: Neutral\n",
    "\n",
    "Text: \"The delivery was fast but the item was broken.\"\n",
    "Sentiment:\"\"\"\n",
    "\n",
    "response = chat([{\"role\": \"user\", \"content\": few_shot_prompt}])\n",
    "print('Few-shot sentiment:', response)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 3. Chain-of-Thought (CoT) Prompting ---\n",
    "cot_prompt = \"\"\"\n",
    "Solve this step by step:\n",
    "\n",
    "A store sells apples for $0.50 each and oranges for $0.75 each.\n",
    "If someone buys 5 apples and 3 oranges, how much do they spend in total?\n",
    "\n",
    "Let me think through this step by step:\n",
    "\"\"\"\n",
    "\n",
    "response = chat([{\"role\": \"user\", \"content\": cot_prompt}])\n",
    "print('CoT response:')\n",
    "print(response)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 4. System Prompt (Persona) ---\n",
    "response = chat([\n",
    "    {\"role\": \"system\", \"content\": \"You are a senior Python engineer who gives concise, practical code reviews. Always point out at least one improvement and one thing done well.\"},\n",
    "    {\"role\": \"user\", \"content\": \"Review this code:\\n\\ndef get_users(db):\\n    users = []\\n    for i in range(1000):\\n        user = db.query(f'SELECT * FROM users WHERE id={i}')\\n        if user:\\n            users.append(user)\\n    return users\"}\n",
    "])\n",
    "print('Code review:')\n",
    "print(response)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 5. Structured Output (JSON) ---\n",
    "response = chat([\n",
    "    {\"role\": \"system\", \"content\": \"Always respond with valid JSON only. No explanation, no markdown.\"},\n",
    "    {\"role\": \"user\", \"content\": \"Extract the name, role, and company from this text:\\n\\n'Hi, I'm Sarah Chen, a Machine Learning Engineer at Anthropic. I work on safety research.'\"}\n",
    "])\n",
    "print('Structured output:')\n",
    "print(response)\n",
    "\n",
    "import json\n",
    "data = json.loads(response)\n",
    "print('\\nParsed:', data)"
   ]
  }
 ],
