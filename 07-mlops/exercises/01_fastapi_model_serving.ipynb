   "source": [
    "# FastAPI Model Serving\n",
    "\n",
    "Serve a trained Scikit-learn model as a production REST API."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# First, let's train and save a simple model\n",
    "import joblib\n",
    "import numpy as np\n",
    "from sklearn.datasets import load_iris\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "\n",
    "# Train model\n",
    "data = load_iris()\n",
    "pipeline = Pipeline([\n",
    "    ('scaler', StandardScaler()),\n",
    "    ('clf', RandomForestClassifier(n_estimators=100, random_state=42))\n",
    "])\n",
    "pipeline.fit(data.data, data.target)\n",
    "\n",
    "# Save model\n",
    "joblib.dump(pipeline, 'iris_model.pkl')\n",
    "print('Model saved: iris_model.pkl')\n",
    "print('Classes:', data.target_names.tolist())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Write the FastAPI app to a file\n",
    "api_code = '''\n",
    "from fastapi import FastAPI, HTTPException\n",
    "from pydantic import BaseModel, Field\n",
    "import joblib\n",
    "import numpy as np\n",
    "from typing import List\n",
    "\n",
    "app = FastAPI(\n",
    "    title=\"Iris Classifier API\",\n",
    "    description=\"Predicts Iris flower species from measurements\",\n",
    "    version=\"1.0.0\"\n",
    ")\n",
    "\n",
    "# Load model at startup\n",
    "model = joblib.load(\"iris_model.pkl\")\n",
    "class_names = [\"setosa\", \"versicolor\", \"virginica\"]\n",
    "\n",
    "class IrisFeatures(BaseModel):\n",
    "    sepal_length: float = Field(..., gt=0, description=\"Sepal length in cm\")\n",
    "    sepal_width: float = Field(..., gt=0, description=\"Sepal width in cm\")\n",
    "    petal_length: float = Field(..., gt=0, description=\"Petal length in cm\")\n",
    "    petal_width: float = Field(..., gt=0, description=\"Petal width in cm\")\n",
    "\n",
    "class PredictionResponse(BaseModel):\n",
    "    prediction: str\n",
    "    confidence: float\n",
    "    probabilities: dict\n",
    "\n",
    "@app.get(\"/health\")\n",
    "def health_check():\n",
    "    return {\"status\": \"healthy\", \"model\": \"iris_classifier_v1\"}\n",
    "\n",
    "@app.post(\"/predict\", response_model=PredictionResponse)\n",
    "def predict(features: IrisFeatures):\n",
    "    X = np.array([[features.sepal_length, features.sepal_width,\n",
    "                   features.petal_length, features.petal_width]])\n",
    "    pred_idx = model.predict(X)[0]\n",
    "    probas = model.predict_proba(X)[0]\n",
    "\n",
    "    return PredictionResponse(\n",
    "        prediction=class_names[pred_idx],\n",
    "        confidence=float(probas[pred_idx]),\n",
    "        probabilities={name: float(prob) for name, prob in zip(class_names, probas)}\n",
    "    )\n",
    "'''\n",
    "\n",
    "with open('api.py', 'w') as f:\n",
    "    f.write(api_code)\n",
    "\n",
    "print('API file created: api.py')\n",
    "print('\\nTo run: uvicorn api:app --reload')\n",
    "print('API docs: http://localhost:8000/docs')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test the API programmatically using requests\n",
    "# (Run after starting: uvicorn api:app --reload)\n",
    "import requests\n",
    "\n",
    "test_data = {\n",
    "    \"sepal_length\": 5.1,\n",
    "    \"sepal_width\": 3.5,\n",
    "    \"petal_length\": 1.4,\n",
    "    \"petal_width\": 0.2\n",
    "}\n",
    "\n",
    "response = requests.post(\"http://localhost:8000/predict\", json=test_data)\n",
    "print(\"Status:\", response.status_code)\n",
    "print(\"Response:\", response.json())"
   ]
  }
